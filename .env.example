# ========================================
# Santa Carmem Notícias - Variáveis
# ========================================
# Copie este arquivo para ".env.local" e preencha com seus dados.
# NUNCA faça commit do .env.local no Git.

# --- Sanity CMS ---
# Crie o projeto em https://sanity.io/manage (grátis).
# Após criar, copie o "Project ID" e o "Dataset" (padrão: production).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Token com permissão de LEITURA apenas (para ISR).
# Gere em https://sanity.io/manage → API → Tokens → "+ Add API token" (Viewer).
SANITY_API_READ_TOKEN=

# Secret do webhook de revalidação (qualquer string aleatória forte).
# Defina o MESMO valor no Sanity: manage → API → Webhooks → secret.
SANITY_REVALIDATE_SECRET=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://santacarmemnoticias.com.br
NEXT_PUBLIC_SITE_NAME="Santa Carmem Notícias"

# --- Google Analytics (opcional) ---
# Crie em https://analytics.google.com → cole o Measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
